# --- v1 backend (classic dashboard) ---
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_WS_BASE=ws://localhost:8000

# --- v2 backend (live MCP browser + full pipeline) ---
# Locally these default to :8001. In Vercel, set them to your Railway URLs.
# Production examples:
#   NEXT_PUBLIC_API_BASE_V2=https://your-v2-backend.up.railway.app
#   NEXT_PUBLIC_WS_BASE_V2=wss://your-v2-backend.up.railway.app
NEXT_PUBLIC_API_BASE_V2=http://localhost:8001
NEXT_PUBLIC_WS_BASE_V2=ws://localhost:8001
