# Which LLM provider to use: nvidia | anthropic | groq | openai | openrouter
LLM_PROVIDER=nvidia

# API keys — fill in only the one for the provider you're using
# NVIDIA NIM (free credits) — https://build.nvidia.com/ -> top right -> Get API Key
NVIDIA_API_KEY=

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Groq (very fast, free tier) — https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenRouter (multi-model) — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: Meta Ad Library API
# https://developers.facebook.com/tools/explorer/  (needs ads_read)
META_ACCESS_TOKEN=

# Optional: Firecrawl (paid). Jina Reader is used free-of-charge by default.
FIRECRAWL_API_KEY=

# Model overrides (leave blank to use provider defaults)
# v2 pipeline defaults (NVIDIA NIM):
#   RESEARCH_MODEL=z-ai/glm-5.1
#   STRATEGY_MODEL=moonshotai/kimi-k2-instruct-0905
#   CREATIVE_MODEL=meta/llama-4-maverick-17b-128e-instruct
STRATEGY_MODEL=
RESEARCH_MODEL=
CREATIVE_MODEL=

# Server port — Railway sets PORT automatically. Locally defaults to 8001.
# PORT=8001
